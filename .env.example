# Database Connection - MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/database_name?retryWrites=true&w=majority&appName=Cluster0

# JWT Secret - Generate a secure random string for production
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL for CORS - Your deployed frontend URL
FRONTEND_URL=https://your-frontend-app.vercel.app

# Environment
NODE_ENV=production

# Port (Vercel will set this automatically)
PORT=3000